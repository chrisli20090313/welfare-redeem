prisma<br>generator client {<br> provider = "prisma-client-js"<br>}<br><br>datasource db {<br> provider = "sqlite"<br> url = env("DATABASE_URL")<br>}<br><br>model Exchange {<br> id Int @id @default(autoincrement())<br> email String @unique<br> plan_selected String<br> recipient_name String<br> recipient_phone String<br> recipient_address String<br> verification_code String?<br> code_expires_at DateTime?<br> status String @default("pending")<br> created_at DateTime @default(now())<br> shipped_at DateTime?<br><br> @@index([email])<br>}<br>
